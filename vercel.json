{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/pages/index.html"
    },
    {
      "source": "/products",
      "destination": "/pages/products.html"
    },
    {
      "source": "/solutions",
      "destination": "/pages/solutions.html"
    },
    {
      "source": "/blog",
      "destination": "/pages/blog.html"
    },
    {
      "source": "/company",
      "destination": "/pages/company.html"
    },
    {
      "source": "/contact",
      "destination": "/pages/contact.html"
    },
    {
      "source": "/threatmap",
      "destination": "/pages/threatmap.html"
    }
  ]
}